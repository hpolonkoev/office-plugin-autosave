                    <Action xsi:type="ShowTaskpane">
                      <TaskpaneId>AutoSaveTaskpane</TaskpaneId>
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>

